{
  "name": "repo-notes",
  "version": "0.1.0",
  "description": "Local-first notes app for rendering and editing text-like files across repositories.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:api": "bun --watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "start": "bun run src/server/index.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "bun test",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "dompurify": "^3.4.5",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
